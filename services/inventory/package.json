    "@ecommerce/shared-middleware": "workspace:*",
    "@ecommerce/shared-telemetry": "workspace:*",
    "@ecommerce/shared-types": "workspace:*",
    "@ecommerce/shared-errors": "workspace:*",
    "@ecommerce/shared-messaging": "workspace:*",
    "express": "^4.18.0",
    "pg": "^8.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
