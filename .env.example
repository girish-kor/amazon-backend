# Environment variables template
# Copy to .env and populate with real values

# Database
DATABASE_URL=postgres://postgres:password@localhost:5432/ecommerce
MONGODB_URI=mongodb://mongo:27017/ecommerce
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ecommerce-client

# Auth
JWT_PRIVATE_KEY_PATH=./keys/private.key
JWT_PUBLIC_KEY_PATH=./keys/public.key
JWT_ACCESS_TOKEN_EXPIRY=900
JWT_REFRESH_TOKEN_EXPIRY=604800
SERVICE_AUTH_SECRET=your-service-secret-here

# Payment Provider
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Observability
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Service Ports
AUTH_SERVICE_PORT=3001
CATALOG_SERVICE_PORT=3002
INVENTORY_SERVICE_PORT=3003
CART_SERVICE_PORT=3004
ORDER_SERVICE_PORT=3005
PAYMENT_SERVICE_PORT=3006
SEARCH_SERVICE_PORT=3007
API_GATEWAY_PORT=3000

# Environment
NODE_ENV=development
LOG_LEVEL=debug
