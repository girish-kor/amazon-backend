{
  "$schema": "http://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/product.deleted.json",
  "title": "Product Deleted Event",
  "description": "Emitted when a product is deleted (soft delete)",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "occurredAt",
    "recordedAt",
    "schemaVersion",
    "correlationId",
    "productId",
    "reason"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "type": "string",
      "enum": ["product.deleted"]
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "recordedAt": {
      "type": "string",
      "format": "date-time"
    },
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "correlationId": {
      "type": "string",
      "format": "uuid"
    },
    "causationId": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "productId": {
      "type": "string",
      "format": "uuid"
    },
    "reason": {
      "type": "string",
      "enum": ["discontin", "admin", "system"]
    }
  },
  "additionalProperties": false
}
