{
  "$schema": "http://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/inventory.reservation_failed.json",
  "title": "Inventory Reservation Failed Event",
  "description": "Emitted when inventory reservation fails due to insufficient stock",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "occurredAt",
    "recordedAt",
    "schemaVersion",
    "correlationId",
    "orderId",
    "failureReason",
    "items"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "type": "string",
      "enum": ["inventory.reservation_failed"]
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "recordedAt": {
      "type": "string",
      "format": "date-time"
    },
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "correlationId": {
      "type": "string",
      "format": "uuid"
    },
    "causationId": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "orderId": {
      "type": "string",
      "format": "uuid"
    },
    "failureReason": {
      "type": "string",
      "enum": ["insufficient_stock", "product_not_found"]
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["productId", "requested"],
        "properties": {
          "productId": {
            "type": "string",
            "format": "uuid"
          },
          "requested": {
            "type": "integer",
            "minimum": 1
          },
          "available": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  },
  "additionalProperties": false
}
