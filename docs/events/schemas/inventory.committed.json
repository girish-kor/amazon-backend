{
  "$schema": "http://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/inventory.committed.json",
  "title": "Inventory Committed Event",
  "description": "Emitted when a reservation is committed to actual inventory deduction (after successful payment)",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "occurredAt",
    "recordedAt",
    "schemaVersion",
    "correlationId",
    "orderId",
    "items"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "type": "string",
      "enum": ["inventory.committed"]
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "recordedAt": {
      "type": "string",
      "format": "date-time"
    },
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "correlationId": {
      "type": "string",
      "format": "uuid"
    },
    "causationId": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "orderId": {
      "type": "string",
      "format": "uuid"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["productId", "quantity"],
        "properties": {
          "productId": {
            "type": "string",
            "format": "uuid"
          },
          "quantity": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  },
  "additionalProperties": false
}
