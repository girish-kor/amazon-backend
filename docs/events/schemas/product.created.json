{
  "$schema": "http://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/product.created.json",
  "title": "Product Created Event",
  "description": "Emitted when a product is created in the catalog",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "occurredAt",
    "recordedAt",
    "schemaVersion",
    "correlationId",
    "productId",
    "sku",
    "name",
    "basePrice",
    "currency",
    "categoryId"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "type": "string",
      "enum": ["product.created"]
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "recordedAt": {
      "type": "string",
      "format": "date-time"
    },
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "correlationId": {
      "type": "string",
      "format": "uuid"
    },
    "causationId": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "productId": {
      "type": "string",
      "format": "uuid"
    },
    "sku": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": ["string", "null"]
    },
    "basePrice": {
      "type": "number",
      "minimum": 0
    },
    "currency": {
      "type": "string",
      "enum": ["USD", "EUR", "GBP", "INR"]
    },
    "categoryId": {
      "type": "string",
      "format": "uuid"
    },
    "attributes": {
      "type": "object",
      "additionalProperties": true
    },
    "images": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      }
    }
  },
  "additionalProperties": false
}
